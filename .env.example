AMO_BASE_URL=https://your-subdomain.amocrm.ru
AMO_ACCESS_TOKEN=your_long_lived_token
PORT=3000

# Воронка, которую зеркалим (id из amoCRM). Пусто = все воронки.
PIPELINE_ID=

# Секретный токен в URL вебхука и реконсиляции:
#   https://<домен>/webhook/<AMO_WEBHOOK_SECRET>
#   https://<домен>/resync/<AMO_WEBHOOK_SECRET>
# Без него эндпоинты /webhook и /resync отключены. Сгенерируйте длинную случайную строку.
AMO_WEBHOOK_SECRET=

# Строка подключения к Postgres (Neon → Connection string, pooled).
# Формат: postgres://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=
